# ---------- Frontend (Vite) ----------
# URL base do backend HTTP em produção (ex: Railway)
VITE_API_URL=https://seu-backend.up.railway.app/api

# URL base do Socket.IO em produção (normalmente igual ao backend)
VITE_SOCKET_URL=https://seu-backend.up.railway.app

# ---------- Backend (Express) ----------
# Porta local (em produção o host injeta automaticamente)
PORT=3001

# Origens permitidas para CORS/Socket.IO
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_ORIGINS=http://localhost:5173,https://seu-frontend.vercel.app

# Banco de dados
DATABASE_URL=

# IA (OpenAI)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Sessão do WhatsApp (local)
WHATSAPP_AUTH_PATH=
